<Window x:Class="CodeTyper.Wpf.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodeTyper" Width="520" SizeToContent="Height"
        Background="#0f1117" Foreground="#e2e8f0"
        FontFamily="Segoe UI" FontSize="14"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

  <Window.Resources>
    <Style x:Key="Btn" TargetType="Button">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    CornerRadius="10" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#252836"/>
      <Setter Property="Foreground" Value="#e2e8f0"/>
      <Setter Property="BorderBrush" Value="#2e3347"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CaretBrush" Value="#e2e8f0"/>
      <Setter Property="FontSize" Value="15"/>
    </Style>
  </Window.Resources>

  <StackPanel Margin="40">

    <!-- Logo -->
    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,36">
      <TextBlock Text="⌨" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,8"/>
      <TextBlock Text="CodeTyper" FontSize="32" FontWeight="Bold"
                 Foreground="#6366f1" HorizontalAlignment="Center"/>
      <TextBlock Text="Typing Speed Challenge" FontSize="13"
                 Foreground="#8892a4" HorizontalAlignment="Center" Margin="0,4,0,0"/>
    </StackPanel>

    <!-- Player Name -->
    <TextBlock Text="Player Name" Foreground="#8892a4" FontSize="12"
               FontWeight="SemiBold" Margin="0,0,0,6"/>
    <TextBox x:Name="PlayerNameBox" Text="" Height="42"
             VerticalContentAlignment="Center" Margin="0,0,0,28"/>

    <!-- Divider -->
    <Border BorderBrush="#2e3347" BorderThickness="0,1,0,0" Margin="0,0,0,28"/>

    <!-- Global -->
    <TextBlock Text="Global Ranking" Foreground="#8892a4" FontSize="12"
               FontWeight="SemiBold" Margin="0,0,0,8"/>
    <Button x:Name="GlobalBtn" Content="Play — Global Ranking"
            Background="#6366f1" Padding="0,16" Style="{StaticResource Btn}"
            Click="GlobalBtn_Click" Margin="0,0,0,24"/>

    <!-- Group -->
    <TextBlock Text="Group Ranking" Foreground="#8892a4" FontSize="12"
               FontWeight="SemiBold" Margin="0,0,0,8"/>
    <Grid Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBox x:Name="GroupIdBox" Grid.Column="0" Height="42"
               VerticalContentAlignment="Center"
               Text="" Tag="Enter Group ID...">
        <TextBox.Style>
          <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Style.Triggers>
              <Trigger Property="Text" Value="">
                <Setter Property="Background">
                  <Setter.Value>
                    <VisualBrush Stretch="None" AlignmentX="Left">
                      <VisualBrush.Visual>
                        <TextBlock Text="Enter Group ID..." Foreground="#4a5568"
                                   Margin="12,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                      </VisualBrush.Visual>
                    </VisualBrush>
                  </Setter.Value>
                </Setter>
              </Trigger>
            </Style.Triggers>
          </Style>
        </TextBox.Style>
      </TextBox>
      <Button x:Name="GroupBtn" Grid.Column="2" Content="Play — Group Ranking"
              Background="#0e7490" Padding="20,0" Height="42"
              Style="{StaticResource Btn}" Click="GroupBtn_Click"/>
    </Grid>
    <TextBlock Text="Players in the same Group ID compete together."
               Foreground="#4a5568" FontSize="12" Margin="0,0,0,28"/>

    <!-- View Ranking -->
    <Border BorderBrush="#2e3347" BorderThickness="0,1,0,0" Margin="0,0,0,20"/>
    <Button x:Name="RankingBtn" Content="View Ranking"
            Background="#1a1d27" Padding="0,12" Style="{StaticResource Btn}"
            Click="RankingBtn_Click">
      <Button.Template>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd" Background="{TemplateBinding Background}"
                  BorderBrush="#2e3347" BorderThickness="1" CornerRadius="10"
                  Padding="{TemplateBinding Padding}">
            <TextBlock Text="{TemplateBinding Content}" Foreground="#8892a4"
                       HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="BorderBrush" Value="#6366f1"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Button.Template>
    </Button>

  </StackPanel>
</Window>

<Window x:Class="CodeTyper.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodeTyper" Height="720" Width="1100"
        Background="#0f1117" Foreground="#e2e8f0"
        FontFamily="Segoe UI" FontSize="14"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <Style x:Key="BtnBase" TargetType="Button">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="14,7"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="7"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
      <Setter Property="Background" Value="#6366f1"/>
    </Style>
    <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
      <Setter Property="Background" Value="#22c55e"/>
    </Style>
    <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnBase}">
      <Setter Property="Background" Value="#ef4444"/>
    </Style>
    <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
      <Setter Property="Background" Value="#252836"/>
      <Setter Property="Foreground" Value="#e2e8f0"/>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#252836"/>
      <Setter Property="Foreground" Value="#e2e8f0"/>
      <Setter Property="BorderBrush" Value="#2e3347"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="8,5"/>
      <Setter Property="CaretBrush" Value="#e2e8f0"/>
    </Style>

    <!-- ComboBoxItem -->
    <Style TargetType="ComboBoxItem">
      <Setter Property="Background" Value="#252836"/>
      <Setter Property="Foreground" Value="#e2e8f0"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#3a3d52"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#6366f1"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
      <Setter Property="Background" Value="#252836"/>
      <Setter Property="Foreground" Value="#e2e8f0"/>
      <Setter Property="BorderBrush" Value="#2e3347"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="8,6"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <Border x:Name="border"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="6"/>
              <DockPanel Margin="8,0,0,0">
                <ToggleButton DockPanel.Dock="Right" Width="28"
                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                              Background="Transparent" BorderThickness="0" Cursor="Hand">
                  <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                      <Border Background="Transparent">
                        <TextBlock Text="▾" Foreground="#8892a4" FontSize="12"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                    </ControlTemplate>
                  </ToggleButton.Template>
                </ToggleButton>
                <ContentPresenter x:Name="ContentSite"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  VerticalAlignment="Center"
                                  IsHitTestVisible="False"/>
              </DockPanel>
              <Popup x:Name="PART_Popup"
                     IsOpen="{TemplateBinding IsDropDownOpen}"
                     AllowsTransparency="True" Focusable="False"
                     PopupAnimation="Slide" Placement="Bottom">
                <Border Background="#252836" BorderBrush="#2e3347" BorderThickness="1"
                        CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}">
                  <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="12" Opacity="0.5" ShadowDepth="4"/>
                  </Border.Effect>
                  <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <ItemsPresenter/>
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="BorderBrush" Value="#6366f1"/>
              </Trigger>
              <Trigger Property="IsDropDownOpen" Value="True">
                <Setter TargetName="border" Property="BorderBrush" Value="#6366f1"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="TabItem">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#8892a4"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="18,10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="bd" Background="Transparent"
                    BorderThickness="0,0,0,3" BorderBrush="Transparent"
                    Padding="{TemplateBinding Padding}">
              <TextBlock x:Name="txt"
                         Text="{TemplateBinding Header}"
                         Foreground="{TemplateBinding Foreground}"
                         FontWeight="{TemplateBinding FontWeight}"
                         FontSize="{TemplateBinding FontSize}"
                         VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="bd"  Property="BorderBrush" Value="#6366f1"/>
                <Setter TargetName="txt" Property="Foreground"  Value="#e2e8f0"/>
                <Setter TargetName="txt" Property="FontWeight"  Value="Bold"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="txt" Property="Foreground" Value="#c7d0e0"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="Card" TargetType="Border">
      <Setter Property="Background" Value="#1a1d27"/>
      <Setter Property="BorderBrush" Value="#2e3347"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="20"/>
    </Style>
  </Window.Resources>

  <DockPanel>
    <!-- Header -->
    <Border DockPanel.Dock="Top" Background="#1a1d27" BorderBrush="#2e3347"
            BorderThickness="0,0,0,1" Padding="20,0">
      <DockPanel Height="52">
        <TextBlock Text="CodeTyper" FontSize="18" FontWeight="Bold"
                   Foreground="#6366f1" VerticalAlignment="Center"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Content="Home" Click="HomeBtn_Click"
                  Background="#252836" Foreground="#8892a4"
                  BorderBrush="#2e3347" BorderThickness="1"
                  Padding="12,5" Margin="0,0,12,0" Cursor="Hand" FontSize="12">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border x:Name="bd" Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                    TextElement.Foreground="{TemplateBinding Foreground}"
                                    TextElement.FontSize="{TemplateBinding FontSize}"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="BorderBrush" Value="#6366f1"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
          </Button>
          <TextBlock x:Name="StatusText" Text="API connecting..."
                     Foreground="#8892a4" FontSize="12" VerticalAlignment="Center"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <TabControl x:Name="MainTabControl" Background="#0f1117" BorderThickness="0" Padding="0"
                SelectionChanged="MainTabControl_SelectionChanged">
      <TabControl.Template>
        <ControlTemplate TargetType="TabControl">
          <DockPanel>
            <!-- タブバー -->
            <Border DockPanel.Dock="Top" Background="#1a1d27"
                    BorderBrush="#2e3347" BorderThickness="0,0,0,1">
              <TabPanel IsItemsHost="True" Background="Transparent" Margin="8,0"/>
            </Border>
            <!-- コンテンツ -->
            <ContentPresenter ContentSource="SelectedContent"/>
          </DockPanel>
        </ControlTemplate>
      </TabControl.Template>

      <!-- Practice Tab -->
      <TabItem Header="Practice">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="20" MaxWidth="900">

            <!-- Mode Selection -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Mode Selection" Foreground="#8892a4" FontSize="11"
                           FontWeight="Bold" Margin="0,0,0,12"/>
                <WrapPanel>
                  <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Language" Foreground="#8892a4" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox x:Name="LangCombo" Width="160"
                              SelectionChanged="LangCombo_Changed"/>
                  </StackPanel>
                  <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Difficulty" Foreground="#8892a4" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox x:Name="DiffCombo" Width="140"
                              SelectionChanged="DiffCombo_Changed"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Text="Word Count" Foreground="#8892a4" FontSize="11" Margin="0,0,0,4"/>
                    <Border Background="#252836" BorderBrush="#2e3347" BorderThickness="1"
                            CornerRadius="6" Padding="12,8" Width="100">
                      <TextBlock Text="20" HorizontalAlignment="Center" Foreground="#e2e8f0"/>
                    </Border>
                  </StackPanel>
                </WrapPanel>

                <WrapPanel x:Name="ScopePanel" Margin="0,14,0,0">
                  <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Ranking Scope" Foreground="#8892a4" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ScopeCombo" Width="140" SelectionChanged="ScopeCombo_Changed">
                      <ComboBoxItem Content="Global" Tag="global" IsSelected="True"/>
                      <ComboBoxItem Content="Team" Tag="team"/>
                    </ComboBox>
                  </StackPanel>
                  <StackPanel x:Name="TeamIdPanel" Visibility="Collapsed" Margin="0,0,20,0">
                    <TextBlock Text="Team ID" Foreground="#8892a4" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox x:Name="TeamIdBox" Width="140" Text="team-a"/>
                  </StackPanel>
                </WrapPanel>
              </StackPanel>
            </Border>

            <!-- Player Name -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
              <StackPanel>
                <TextBlock Text="Player Name" Foreground="#8892a4" FontSize="11"
                           FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBox x:Name="PlayerNameBox" Text="Player1" Width="220"
                         HorizontalAlignment="Left" FontSize="14"/>
              </StackPanel>
            </Border>

            <!-- Practice Area -->
            <Border Style="{StaticResource Card}">
              <StackPanel>

                <!-- Live Stats -->
                <Border Background="#252836" BorderBrush="#2e3347" BorderThickness="1"
                        CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                  <UniformGrid Columns="4">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock x:Name="LiveScore" Text="0" FontSize="28" FontWeight="Bold"
                                 Foreground="#6366f1" HorizontalAlignment="Center"/>
                      <TextBlock Text="Score" Foreground="#8892a4" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock x:Name="LiveWpm" Text="0" FontSize="28" FontWeight="Bold"
                                 Foreground="#6366f1" HorizontalAlignment="Center"/>
                      <TextBlock Text="WPM" Foreground="#8892a4" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock x:Name="LiveAcc" Text="100" FontSize="28" FontWeight="Bold"
                                 Foreground="#6366f1" HorizontalAlignment="Center"/>
                      <TextBlock Text="Acc%" Foreground="#8892a4" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock x:Name="LiveTime" Text="60" FontSize="28" FontWeight="Bold"
                                 Foreground="#f59e0b" HorizontalAlignment="Center"/>
                      <TextBlock Text="sec" Foreground="#8892a4" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </UniformGrid>
                </Border>

                <!-- Progress -->
                <DockPanel Margin="0,0,0,8">
                  <TextBlock x:Name="ProgressText" Text="0 / 0" Foreground="#8892a4"
                             FontSize="12" DockPanel.Dock="Right"/>
                  <TextBlock Text="Progress" Foreground="#8892a4" FontSize="12"/>
                </DockPanel>
                <Border Background="#252836" BorderBrush="#2e3347" BorderThickness="1"
                        CornerRadius="4" Height="6" Margin="0,0,0,16" ClipToBounds="True">
                  <Border x:Name="ProgressBar" Background="#6366f1" HorizontalAlignment="Left"
                          Width="0" CornerRadius="4"/>
                </Border>

                <!-- Current Word Display -->
                <Border x:Name="WordDisplayCard"
                        Background="#0f1117" BorderBrush="#6366f1" BorderThickness="2"
                        CornerRadius="10" Padding="24,20" Margin="0,0,0,16"
                        HorizontalAlignment="Stretch" MinWidth="400">
                  <StackPanel HorizontalAlignment="Stretch">
                    <TextBlock Text="Type this word:" Foreground="#8892a4" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <ScrollViewer x:Name="CurrentWordScrollViewer"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  Height="48">
                      <TextBlock x:Name="CurrentWordText" Text="---"
                                 FontFamily="Cascadia Code, Consolas, monospace"
                                 FontSize="36" FontWeight="Bold" Foreground="#e2e8f0"
                                 TextWrapping="NoWrap"/>
                    </ScrollViewer>
                    <!-- 次の単語プレビュー -->
                    <TextBlock x:Name="NextWordText" Text=""
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="14" Foreground="#4a5568"
                               HorizontalAlignment="Stretch"
                               TextAlignment="Left"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,8,0,0"/>
                  </StackPanel>
                </Border>

                <!-- Input -->
                <TextBox x:Name="InputBox"
                         FontFamily="Cascadia Code, Consolas, monospace"
                         FontSize="20" Height="52" TextAlignment="Left"
                         IsEnabled="False" TextChanged="InputBox_TextChanged"
                         KeyDown="InputBox_KeyDown"
                         Margin="0,0,0,16"/>

                <!-- Feedback -->
                <TextBlock x:Name="FeedbackText" Text="" FontSize="14" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,12" Height="20"/>

                <!-- Buttons -->
                <WrapPanel HorizontalAlignment="Center">
                  <Button x:Name="StartBtn" Content="Start Game" Style="{StaticResource BtnPrimary}"
                          Click="StartBtn_Click" Margin="0,0,8,0" Padding="20,10"/>
                  <Button x:Name="RetryBtn" Content="Play Again" Style="{StaticResource BtnSecondary}"
                          Click="RetryBtn_Click" Visibility="Collapsed" Padding="20,10" Margin="0,0,8,0"/>
                  <Button x:Name="ViewRankingBtn" Content="View Ranking" Style="{StaticResource BtnPrimary}"
                          Click="ViewRanking_Click" Visibility="Collapsed" Padding="20,10"/>
                </WrapPanel>

                <!-- Result Card -->
                <Border x:Name="ResultCard" Background="#252836" BorderBrush="#2e3347"
                        BorderThickness="1" CornerRadius="8" Padding="24" Margin="0,20,0,0"
                        Visibility="Collapsed">
                  <StackPanel>
                    <TextBlock Text="Game Over!" FontSize="18" FontWeight="Bold"
                               Foreground="#e2e8f0" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <UniformGrid Columns="4">
                      <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="ResScore" Text="-" FontSize="30" FontWeight="Bold"
                                   Foreground="#6366f1" HorizontalAlignment="Center"/>
                        <TextBlock Text="Score" Foreground="#8892a4" FontSize="12" HorizontalAlignment="Center"/>
                      </StackPanel>
                      <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="ResWpm" Text="-" FontSize="30" FontWeight="Bold"
                                   Foreground="#6366f1" HorizontalAlignment="Center"/>
                        <TextBlock Text="WPM" Foreground="#8892a4" FontSize="12" HorizontalAlignment="Center"/>
                      </StackPanel>
                      <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="ResAcc" Text="-" FontSize="30" FontWeight="Bold"
                                   Foreground="#6366f1" HorizontalAlignment="Center"/>
                        <TextBlock Text="Accuracy" Foreground="#8892a4" FontSize="12" HorizontalAlignment="Center"/>
                      </StackPanel>
                      <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="ResCorrect" Text="-" FontSize="30" FontWeight="Bold"
                                   Foreground="#22c55e" HorizontalAlignment="Center"/>
                        <TextBlock Text="Correct" Foreground="#8892a4" FontSize="12" HorizontalAlignment="Center"/>
                      </StackPanel>
                    </UniformGrid>
                  </StackPanel>
                </Border>

              </StackPanel>
            </Border>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Ranking Tab -->
      <TabItem Header="Ranking">
        <DockPanel Margin="20">
          <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,16">
            <WrapPanel>
              <StackPanel Margin="0,0,16,0">
                <TextBlock Text="Language" Foreground="#8892a4" FontSize="11" Margin="0,0,0,4"/>
                <ComboBox x:Name="RankLangCombo" Width="130"/>
              </StackPanel>
              <StackPanel Margin="0,0,16,0">
                <TextBlock Text="Difficulty" Foreground="#8892a4" FontSize="11" Margin="0,0,0,4"/>
                <ComboBox x:Name="RankDiffCombo" Width="110"/>
              </StackPanel>
              <StackPanel Margin="0,0,16,0">
                <TextBlock Text="Scope" Foreground="#8892a4" FontSize="11" Margin="0,0,0,4"/>
                <ComboBox x:Name="RankScopeCombo" Width="130" SelectionChanged="RankScopeCombo_Changed">
                  <ComboBoxItem Content="Global" Tag="global" IsSelected="True"/>
                  <ComboBoxItem Content="Team" Tag="team"/>
                </ComboBox>
              </StackPanel>
              <StackPanel x:Name="RankTeamPanel" Visibility="Collapsed" Margin="0,0,16,0">
                <TextBlock Text="Team ID" Foreground="#8892a4" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="RankTeamBox" Width="120" Text="team-a"/>
              </StackPanel>
              <StackPanel Margin="0,0,16,0">
                <TextBlock Text="Top N" Foreground="#8892a4" FontSize="11" Margin="0,0,0,4"/>
                <ComboBox x:Name="RankTopCombo" Width="80">
                  <ComboBoxItem Content="10" Tag="10"/>
                  <ComboBoxItem Content="20" Tag="20" IsSelected="True"/>
                  <ComboBoxItem Content="50" Tag="50"/>
                </ComboBox>
              </StackPanel>
              <StackPanel VerticalAlignment="Bottom">
                <Button Content="Refresh" Style="{StaticResource BtnPrimary}" Click="LoadRanking_Click"/>
              </StackPanel>
            </WrapPanel>
          </Border>

          <Border Style="{StaticResource Card}">
            <DataGrid x:Name="RankingGrid" AutoGenerateColumns="False"
                      Background="Transparent" Foreground="#e2e8f0"
                      BorderThickness="0" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#2e3347" RowBackground="Transparent"
                      AlternatingRowBackground="#1e2130" HeadersVisibility="Column"
                      CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single">
              <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="Foreground" Value="#8892a4"/>
                  <Setter Property="FontSize" Value="11"/>
                  <Setter Property="FontWeight" Value="Bold"/>
                  <Setter Property="Padding" Value="10,8"/>
                  <Setter Property="BorderThickness" Value="0,0,0,1"/>
                  <Setter Property="BorderBrush" Value="#2e3347"/>
                </Style>
              </DataGrid.ColumnHeaderStyle>
              <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                  <Setter Property="Foreground" Value="#e2e8f0"/>
                  <Setter Property="BorderThickness" Value="0"/>
                  <Setter Property="Padding" Value="10,7"/>
                  <Setter Property="Background" Value="Transparent"/>
                </Style>
              </DataGrid.CellStyle>
              <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="50"/>
                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="100"/>
                <DataGridTextColumn Header="WPM" Binding="{Binding Wpm}" Width="80"/>
                <DataGridTextColumn Header="Accuracy" Binding="{Binding Accuracy}" Width="90"/>
                <DataGridTextColumn Header="Date" Binding="{Binding PlayedAt}" Width="160"/>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
        </DockPanel>
      </TabItem>

      <!-- Word Admin Tab -->
      <TabItem Header="Word Admin">
        <DockPanel Margin="20">
          <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,16">
            <WrapPanel>
              <StackPanel Margin="0,0,16,0">
                <TextBlock Text="Language" Foreground="#8892a4" FontSize="11" Margin="0,0,0,4"/>
                <ComboBox x:Name="AdminLangCombo" Width="130"/>
              </StackPanel>
              <StackPanel Margin="0,0,16,0">
                <TextBlock Text="Difficulty" Foreground="#8892a4" FontSize="11" Margin="0,0,0,4"/>
                <ComboBox x:Name="AdminDiffCombo" Width="110"/>
              </StackPanel>
              <StackPanel VerticalAlignment="Bottom" Margin="0,0,8,0">
                <Button Content="Search" Style="{StaticResource BtnPrimary}" Click="SearchWords_Click"/>
              </StackPanel>
              <StackPanel VerticalAlignment="Bottom">
                <Button Content="+ Add" Style="{StaticResource BtnSuccess}" Click="AddWord_Click"/>
              </StackPanel>
            </WrapPanel>
          </Border>

          <Border Style="{StaticResource Card}">
            <DataGrid x:Name="WordGrid" AutoGenerateColumns="False"
                      Background="Transparent" Foreground="#e2e8f0"
                      BorderThickness="0" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#2e3347" RowBackground="Transparent"
                      AlternatingRowBackground="#1e2130" HeadersVisibility="Column"
                      CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single">
              <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="Foreground" Value="#8892a4"/>
                  <Setter Property="FontSize" Value="11"/>
                  <Setter Property="FontWeight" Value="Bold"/>
                  <Setter Property="Padding" Value="10,8"/>
                  <Setter Property="BorderThickness" Value="0,0,0,1"/>
                  <Setter Property="BorderBrush" Value="#2e3347"/>
                </Style>
              </DataGrid.ColumnHeaderStyle>
              <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                  <Setter Property="Foreground" Value="#e2e8f0"/>
                  <Setter Property="BorderThickness" Value="0"/>
                  <Setter Property="Padding" Value="10,7"/>
                  <Setter Property="Background" Value="Transparent"/>
                </Style>
              </DataGrid.CellStyle>
              <DataGrid.Columns>
                <DataGridTextColumn Header="Word" Binding="{Binding Word}" Width="*"/>
                <DataGridTextColumn Header="Language" Binding="{Binding Language}" Width="100"/>
                <DataGridTextColumn Header="Difficulty" Binding="{Binding Difficulty}" Width="90"/>
                <DataGridTextColumn Header="Weight" Binding="{Binding Weight}" Width="70"/>
                <DataGridTextColumn Header="Enabled" Binding="{Binding EnabledText}" Width="70"/>
                <DataGridTemplateColumn Header="Actions" Width="160">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <WrapPanel>
                        <Button Content="Edit" Style="{StaticResource BtnSecondary}"
                                Padding="8,4" Margin="0,0,4,0" FontSize="12"
                                Click="EditWord_Click" Tag="{Binding}"/>
                        <Button Content="Delete" Style="{StaticResource BtnDanger}"
                                Padding="8,4" FontSize="12"
                                Click="DeleteWord_Click" Tag="{Binding}"/>
                      </WrapPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
        </DockPanel>
      </TabItem>

    </TabControl>
  </DockPanel>
</Window>
